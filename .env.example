# Copy to .env and set AUTH_SECRET (e.g. openssl rand -base64 32)
DATABASE_URL="file:./prisma/dev.db"
AUTH_SECRET=""
NVIDIA_API_KEY=""
NVIDIA_API_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_EMBEDDING_MODEL="nvidia/nv-embedqa-e5-v5"
NVIDIA_SEARCH_MODEL="meta/llama-3.1-70b-instruct"
CHROMA_URL="http://localhost:8000"
CHROMA_COLLECTION="published_agents"
